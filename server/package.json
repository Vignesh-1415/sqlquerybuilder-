{
  "name": "statement-server",
  "version": "1.0.0",
  "description": "Statement backend: turns natural-language questions into safe, read-only SQL for an uploaded SQLite file.",
  "main": "src/index.js",
  "type": "commonjs",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "seed:check": "node -e \"require('better-sqlite3')('../seed/sample.sqlite',{readonly:true})\""
  },
  "dependencies": {
    "better-sqlite3": "^11.3.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "express-validator": "^7.2.0",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "multer": "^2.0.0",
    "uuid": "^9.0.1"
  },
  "license": "MIT"
}
